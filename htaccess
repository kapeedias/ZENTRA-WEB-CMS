<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # CLEAN EVENT EDIT URL
  RewriteRule ^event/([A-Za-z0-9]+)/edit$ events-edit.php?e=$1 [L,QSA]

  # REMOVE .PHP EXTENSION
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.php -f
  RewriteRule ^([^/]+)/?$ $1.php [L]

  # BLOCK DIRECT ACCESS TO _include/*.php
  RewriteRule ^_include/.*\.php$ - [F,L]
</IfModule>
